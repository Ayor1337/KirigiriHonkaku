# Health check

GET http://127.0.0.1:8000/api/v1/health
Accept: application/json

###

# Create session

POST http://127.0.0.1:8000/api/v1/sessions
Content-Type: application/json

{}

###

# Bootstrap stream session

POST http://127.0.0.1:8000/api/v1/sessions/bootstrap-stream
Accept: text/event-stream

###

# List sessions

GET http://127.0.0.1:8000/api/v1/sessions
Accept: application/json

###

# Submit action

POST http://127.0.0.1:8000/api/v1/actions
Content-Type: application/json

{
  "session_id": "replace-me",
  "action_type": "move",
  "actor_id": "player",
  "payload": {
    "target_location_id": "lobby"
  }
}

###

# Fetch session

GET http://127.0.0.1:8000/api/v1/sessions/replace-me
Accept: application/json

###
